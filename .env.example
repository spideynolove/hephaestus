# Copy this to .env and fill in your values
# cp .env.example .env
# Or run: bash setup.sh  (guided wizard)

# ── Choose ONE provider block. Uncomment and fill in. ──────────────────────────

# Option A: OAuth subscription only (no API keys needed)
# Run setup.sh and choose option 1. No variables required here.
# WORKER_TOOL_OVERRIDE=claude

# Option B: OpenRouter (free tier — rate-limited ~200 req/day)
# ANTHROPIC_BASE_URL=https://openrouter.ai/api
# ANTHROPIC_AUTH_TOKEN=sk-or-v1-...
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-v1-...
# WORKER_MODEL=qwen/qwen3-coder-480b:free
# REVIEWER_MODEL=deepseek/deepseek-r1:free

# Option C: DeepSeek (paid)
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your-deepseek-key
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_API_KEY=your-deepseek-key
# WORKER_MODEL=deepseek-chat
# REVIEWER_MODEL=deepseek-chat

# Option D: Z.AI / GLM (Reviewer only — Worker falls back to claude)
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# ANTHROPIC_AUTH_TOKEN=your-z-ai-key
# WORKER_TOOL_OVERRIDE=claude
# REVIEWER_MODEL=glm-5.1

# Option E: Official Anthropic + OpenAI
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Option F: Custom endpoint
# ANTHROPIC_BASE_URL=https://your-proxy.example.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your-key
# OPENAI_BASE_URL=https://your-proxy.example.com/v1
# OPENAI_API_KEY=your-key

# ── Notifications (optional — configure any or all) ───────────────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
# TELEGRAM_BOT_TOKEN=123456789:AAF...
# TELEGRAM_CHAT_ID=-100123456789
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
